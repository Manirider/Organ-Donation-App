APP_NAME=OrganDonationPlatform
APP_ENV=development
DEBUG=true

HOST=0.0.0.0
PORT=8000

DATABASE_URL=sqlite+aiosqlite:///./app.db

REDIS_URL=redis://localhost:6379/0

JWT_SECRET_KEY=dev-secret-key-change-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

ENCRYPTION_KEY=dev-encryption-key-32-bytes-ok

OTP_EXPIRY_MINUTES=10
OTP_LENGTH=6

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
EMAIL_FROM=noreply@organdonation.com

TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

SMS_PROVIDER=twilio
SMS_API_KEY=
SMS_SENDER_ID=ORGDNT
